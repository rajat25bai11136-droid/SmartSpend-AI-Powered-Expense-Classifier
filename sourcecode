from sklearn.feature_extraction.text import CountVectorizer
from sklearn.naive_bayes import MultinomialNB
from sklearn.pipeline import make_pipeline

# 1. THE DATASET (Training Data)
# In a real project, this would be a large CSV file.
descriptions = [
    "Uber ride to office", "Starbucks coffee", "Monthly Apartment Rent", 
    "Netflix subscription", "Gas station fill up", "Grocery store apples",
    "Yellow Cab fare", "Dinner at McDonalds", "Electricity bill"
]
categories = [
    "Transport", "Food", "Rent", 
    "Entertainment", "Transport", "Food",
    "Transport", "Food", "Bills"
]

# 2. THE MODEL
# We create a 'pipeline' that converts text to numbers and then trains the model.
model = make_pipeline(CountVectorizer(), MultinomialNB())

# 3. TRAINING
model.fit(descriptions, categories)

# 4. PREDICTION (The "AI" part)
def predict_category(new_description):
    prediction = model.predict([new_description])
    return prediction[0]

# Example Usage:
user_input = "Pizza delivery for party"
result = predict_category(user_input)
print(f"Description: {user_input} | Predicted Category: {result}")
